# Copy to .env and fill in. .env is gitignored.

# Arcade — https://api.arcade.dev  (Dashboard → API Keys)
ARCADE_API_KEY=arc_xxx

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxx

# Single-user demo identity. Use the email of the Google account you'll authorize.
ARCADE_USER_ID=you@example.com

# Optional overrides
CLAUDE_MODEL=claude-sonnet-5
DB_PATH=surprise.db
